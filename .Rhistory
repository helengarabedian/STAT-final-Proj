pF <- 1 - (5/6)^3
pU <- 1 - 0.7^3
round(0.25*pU + 0.75*pF, 4)
priorU <- 0.25
post <- priorU*(pU^3)/(priorU*(pU^3) + (1-priorU)*(pF^3))
round(post, 4)
prob_unfair <- function(n){
pF <- 1 - (5/6)^3
pU <- 1 - 0.7^3
priorU <- 0.25
priorU*(pU^n)/(priorU*(pU^n) + (1-priorU)*(pF^n))
}
round(prob_unfair(3), 4)
n <- 1
while(prob_unfair(n) <= 0.9) n <- n + 1
n
prob_unfair(n)
set.seed(1)
n_trials <- 1000
run_est <- function(n_trials, p_double){
doubles <- rbinom(n_trials, size=1, prob=p_double)
cumsum(doubles) / (1:n_trials)
}
p_fair <- 1/6
p_loaded <- 0.3
fair_sims <- replicate(4, run_est(n_trials, p_fair))
load_sims <- replicate(4, run_est(n_trials, p_loaded))
plot(1:n_trials, fair_sims[,1], type="l", ylim=c(0,0.5),
xlab="Number of rolls", ylab="Running estimate P(doubles)")
for(i in 2:4) lines(1:n_trials, fair_sims[,i], col="seagreen")
for(i in 1:4) lines(1:n_trials, load_sims[,i], col="tomato")
legend("topright",
legend=c("Fair dice (4 sims)", "Loaded dice (4 sims)"),
col=c("seagreen", "tomato"), lty=1, bty="n")
