monty_sim_n(n = 3, m = 200000)
switch_pick <- other_closed[1]
set.seed(1)
monty_sim_n <- function(n, m = 100000){
win_stick <- 0L
win_switch <- 0L
doors <- 1:n
for(trial in 1:m){
prize <- sample(doors, 1)
pick  <- sample(doors, 1)
can_open <- setdiff(doors, c(pick, prize))
opened <- sample(can_open, n - 2)
remaining_closed <- setdiff(doors, opened)
other_closed <- setdiff(remaining_closed, pick)
if(pick == prize) win_stick <- win_stick + 1L
switch_pick <- other_closed[1]
if(switch_pick == prize) win_switch <- win_switch + 1L
}
c(stick = win_stick/m, switch = win_switch/m)
}
monty_sim_n(n = 3, m = 200000)
monty_sim_n(n = 4, m = 200000)
monty_sim_n(n = 10, m = 200000)
